meta {
  name: Get Meta Integration
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/meta/integration
  body: none
  auth: none
}

headers {
  Cookie: auth_token={{authToken}}
}

docs {
  Response now includes field_mappings (per-org override of Meta form
  field keys, or null if the org hasn't customized any mappings — in
  which case DEFAULT_FIELD_MAPPINGS in meta.config.ts applies).
}
