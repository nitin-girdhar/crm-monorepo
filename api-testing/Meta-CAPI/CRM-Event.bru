meta {
  name: Send CRM Conversion Event (Manual)
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/meta/crm-event
  body: json
  auth: none
}

headers {
  Cookie: auth_token={{authToken}}
}

body:json {
  {
    "marketingLeadId": "{{leadId}}",
    "eventName": "Lead",
    "actionSource": "system_generated",
    "eventSourceUrl": "https://example.com/leads"
  }
}
