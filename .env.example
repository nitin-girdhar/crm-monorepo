# ─────────────────────────────────────────────────────────────────────────────
# Shared across all backend services
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL connection components ──────────────────────────────────────────
# Change these to point at your Postgres instance. docker-compose.yml reads
# these variables too, so one edit here updates everything.
DB_NAME=crm
DB_HOST=localhost
DB_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=Passw0rd

# Docker container name (used by docker-compose as the network hostname)
DB_CONTAINER_NAME=crm-db-server

# Host path for Postgres data (persistent across container recreates)
DB_DATA_PATH=C:/Girdhar/database_files

# Service-role credentials (created by 01_init-db.sql)
DB_LEAD_SVC_USER=lead_svc
DB_LEAD_SVC_PASSWORD=LeadSvc_Dev2025
DB_TENANT_SVC_USER=tenant_dash_svc
DB_TENANT_SVC_PASSWORD=TenantSvc_Dev2025
DB_SERVICE_USER=crm_service
DB_SERVICE_PASSWORD=CrmSvc_Dev2025

# ── Composed DATABASE_URLs (local dev — services outside Docker) ─────────────
# These use DB_HOST (localhost). docker-compose overrides them with the
# container hostname so you never need to touch docker-compose.yml.
DATABASE_URL=postgres://lead_svc:LeadSvc_Dev2025@localhost:5432/crm
DATABASE_URL_TENANT=postgres://tenant_dash_svc:TenantSvc_Dev2025@localhost:5432/crm
DATABASE_URL_SERVICE=postgres://crm_service:CrmSvc_Dev2025@localhost:5432/crm

# PostgreSQL pool tuning
PG_MAX=10
PG_IDLE_TIMEOUT=30

# PostgreSQL SSL (production)
PG_SSL_MODE=disable             # Force SSL off (local dev, Docker network)
# PG_SSL_CA_PATH=/path/to/ca.pem  # Path to CA certificate file
# PG_SSL_CA=                    # Inline CA certificate (alternative to PG_SSL_CA_PATH)

# JWT
JWT_SECRET=change-me-to-a-long-random-string-at-least-64-chars
# JWT_SECRET must be the SAME value across all services that verify tokens

# Inter-service authentication — gateway injects this header, services reject without it
INTERNAL_SERVICE_SECRET=change-me-to-another-long-random-string

# API key for the intake webhook endpoint (pre-shared with ad platform integrations)
WEBHOOK_API_KEY=change-me-webhook-key

# ─────────────────────────────────────────────────────────────────────────────
# Service ports
# ─────────────────────────────────────────────────────────────────────────────
GATEWAY_PORT=4000
AUTH_SERVICE_PORT=4001
USERS_SERVICE_PORT=4002
LEADS_SERVICE_PORT=4003
ASSIGNMENTS_SERVICE_PORT=4004
ANALYTICS_SERVICE_PORT=4005
ACTIVITIES_SERVICE_PORT=4006
META_SERVICE_PORT=4007
NOTIFICATIONS_SERVICE_PORT=4008
COMMUNICATION_SERVICE_PORT=4009

# ─────────────────────────────────────────────────────────────────────────────
# Internal service URLs (used by api-gateway and inter-service calls)
# ─────────────────────────────────────────────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:4001
USERS_SERVICE_URL=http://localhost:4002
LEADS_SERVICE_URL=http://localhost:4003
ASSIGNMENTS_SERVICE_URL=http://localhost:4004
ANALYTICS_SERVICE_URL=http://localhost:4005
ACTIVITIES_SERVICE_URL=http://localhost:4006
META_SERVICE_URL=http://localhost:4007
NOTIFICATIONS_SERVICE_URL=http://localhost:4008
COMMUNICATION_SERVICE_URL=http://localhost:4009
FOLLOWUP_CHECK_INTERVAL_MS=60000
FOLLOWUP_LOOKAHEAD_MINUTES=5

# ─────────────────────────────────────────────────────────────────────────────
# Communication service (email + WhatsApp)
# ─────────────────────────────────────────────────────────────────────────────
# SMTP / Email (all required for email to be enabled)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=Your App Name

# WhatsApp via Interakt (required for WhatsApp to be enabled)
INTERAKT_API_KEY=your-interakt-api-key
# INTERAKT_API_BASE_URL=https://api.interakt.ai/v1/public/

# ─────────────────────────────────────────────────────────────────────────────
# Auth service
# ─────────────────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─────────────────────────────────────────────────────────────────────────────
# App environment
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# Web app (Next.js — apps/web)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
# JWT_SECRET must also be set for middleware.ts Edge JWT validation

# Gateway
WEB_URL=http://localhost:3000
